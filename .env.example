DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Grafana Cloud OTLP gateway endpoint (no trailing slash)
# Format: https://otlp-gateway-<region>.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp

# Grafana Cloud stack instance ID (numeric — found in Stack > Details)
GRAFANA_INSTANCE_ID=123456

# Grafana API key with MetricsPublisher + LogsPublisher + TracesPublisher scopes
GRAFANA_API_TOKEN=glc_eyJ...

# Service name shown in Grafana
OTEL_SERVICE_NAME=the-shop-product-api

# debug | info | warn | error
LOG_LEVEL=info
