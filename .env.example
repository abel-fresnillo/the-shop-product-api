DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Shared secret for API authentication — 32-byte hex string (64 chars)
# Generate with: openssl rand -hex 32
PRODUCT_API_KEY=your-32-byte-hex-string-here

# Grafana Cloud OTLP gateway endpoint (no trailing slash)
# Format: https://otlp-gateway-<region>.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp

# Grafana Cloud stack instance ID (numeric — found in Stack > Details)
GRAFANA_INSTANCE_ID=123456

# Grafana API key with MetricsPublisher + LogsPublisher + TracesPublisher scopes
GRAFANA_API_TOKEN=glc_eyJ...

# Service name shown in Grafana
OTEL_SERVICE_NAME=the-shop-product-api

# Grafana Cloud Loki push endpoint (no trailing slash)
# Format: https://logs-prod-<region>.grafana.net
LOKI_HOST=https://logs-prod-us-east-0.grafana.net

# Grafana Cloud Loki user ID (numeric — found in Stack > Loki > Details > User)
# Different from GRAFANA_INSTANCE_ID which is used for OTLP
LOKI_USER=123456

# debug | info | warn | error
LOG_LEVEL=info
